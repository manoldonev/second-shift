{
  "$schema": "https://raw.githubusercontent.com/manoldonev/second-shift/v2.1.6/schema/second-shift.config.schema.json",
  "configVersion": 1,
  "tracker": {
    "type": "github",
    "branchPrefix": "claude/second-shift-"
  },
  "topology": {
    "type": "standalone",
    "repos": { "second-shift": { "path": ".", "baseBranch": "main" } }
  },
  "commands": {
    "second-shift": {
      "lint": "find . -name '*.sh' -type f -print0 | xargs -0 shellcheck -e SC1091,SC2015,SC2181",
      "lintAutofixes": false,
      "typecheck": null,
      "test": "find . -name '*-selftest.sh' -type f -print0 | xargs -0 -n1 -I{} env SKIP_STRESS=1 bash {}",
      "build": null,
      "format": null,
      "testFile": null,
      "unitTestScope": null,
      "integrationTest": null,
      "apiTest": null
    }
  },
  "gates": {
    "costTracking": true
  }
}

{
  "$schema": "https://raw.githubusercontent.com/manoldonev/second-shift/v2.1.6/schema/second-shift.config.schema.json",
  "configVersion": 1,
  "tracker": {
    "type": "github",
    "branchPrefix": "claude/second-shift-",
    "bot": {
      "enabled": true,
      "envVar": "GH_BOT",
      "wrapperPath": "~/.config/second-shift/gh-as-bot.sh",
      "app": {
        "clientId": "Iv23linWw3EWmAuuAiZP",
        "appName": "cadenza-dev-pipeline",
        "privateKeyFilename": "cadenza-dev-pipeline.private-key.pem",
        "installationId": "119943793"
      }
    }
  },
  "topology": {
    "type": "standalone",
    "repos": {
      "second-shift": {
        "path": ".",
        "baseBranch": "main"
      }
    }
  },
  "commands": {
    "second-shift": {
      "lint": "find . -name '*.sh' -type f -print0 | xargs -0 shellcheck -e SC1091,SC2015,SC2181",
      "lintAutofixes": false,
      "typecheck": null,
      "test": "find . -name '*-selftest.sh' -type f -print0 | xargs -0 -n1 -I{} env SKIP_STRESS=1 bash {}",
      "build": null,
      "format": null,
      "testFile": null,
      "unitTestScope": null
    }
  }
}

{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/audit-tool-calls.sh\"", "timeout": 5 }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/audit-tool-calls.sh\"", "timeout": 5 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/audit-tool-calls.sh\"", "timeout": 5 }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/audit-tool-calls.sh\"", "timeout": 5 }
        ]
      }
    ]
  }
}
